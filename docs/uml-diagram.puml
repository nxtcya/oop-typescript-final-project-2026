@startuml
title Appointment Booking System - Class Diagram


enum ServiceStatus {
  ACTIVE
  INACTIVE
  MAINTENANCE
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
  NO_SHOW
}


class Service {
  +id: string
  +code: string
  +name: string
  +description: string
  +durationMinutes: number
  +price: number
  +status: ServiceStatus
  +maxBookingsPerSlot: number
  +allowWalkIn: boolean
  +createdAt: Date
  +updatedAt: Date
}

class Appointment {
  +id: string
  +bookingCode: string
  +serviceId: string
  +customerName: string
  +customerAge : number
  +customerPhone: string
  +customerEmail : string 
  +startTime: Date
  +endTime: Date
  +status: AppointmentStatus
  +isPaid: boolean
  +note: string
  +createdAt: Date
  +updatedAt: Date
}

Service "1" -- "0..*" Appointment : has
Service ..> ServiceStatus
Appointment ..> AppointmentStatus

@enduml