  "components": {
    "schemas": {

      "CreateServiceDto": {
        "type": "object",
        "required": [
          "name",
          "description",
          "durationMinutes",
          "price",
          "isActive",
          "requiresAdvancePayment",
          "maxCapacity",
          "category"
        ],
        "properties": {
          "name": {
            "type": "string",
            "description": "ชื่อบริการ",
            "example": "นวดแผนไทย"
          },
          "description": {
            "type": "string",
            "description": "รายละเอียดบริการ",
            "example": "นวดผ่อนคลาย 60 นาที"
          },
          "durationMinutes": {
            "type": "number",
            "description": "ระยะเวลา (นาที)",
            "example": 60
          },
          "price": {
            "type": "number",
            "description": "ราคา",
            "example": 500
          },
          "isActive": {
            "type": "boolean",
            "description": "เปิดให้บริการหรือไม่",
            "example": true
          },
          "requiresAdvancePayment": {
            "type": "boolean",
            "description": "ต้องจ่ายเงินล่วงหน้าหรือไม่",
            "example": false
          },
          "maxCapacity": {
            "type": "number",
            "description": "รับลูกค้าได้สูงสุดต่อรอบ",
            "example": 2
          },
          "category": {
            "type": "string",
            "enum": ["HAIR_CARE", "SKIN_CARE", "MASSAGE", "CONSULTATION"],
            "description": "หมวดหมู่บริการ"
          }
        }
      }

    }
  }
}